# Solana Network (mainnet-beta, devnet, or localnet)
VITE_SOLANA_NETWORK=devnet

# Helius RPC endpoints (optional - will use public RPC if not provided)
VITE_HELIUS_RPC=https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY
VITE_HELIUS_DEVNET_RPC=https://devnet.helius-rpc.com/?api-key=YOUR_API_KEY

# TaskSama Program ID (will be generated after anchor deploy)
VITE_PROGRAM_ID=TaskSama11111111111111111111111111111111111

# Backend API URL
VITE_BACKEND_URL=http://localhost:3000

# Demo mode: populate the UI with fictitious tasks when the Solana program
# is not deployed (no real on-chain task data). Set to "true" for demos.
VITE_DEMO_MODE=false
