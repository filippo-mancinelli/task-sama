# Task-Sama Backend Environment Variables - Solana Version

# PostgreSQL Database
DATABASE_URL=postgresql://username:password@localhost:5432/tasksama

# Solana Configuration
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet
PROGRAM_ID=TaskSama11111111111111111111111111111111111

# Helius Configuration (for webhooks)
HELIUS_API_KEY=your_helius_api_key_here
HELIUS_WEBHOOK_SECRET=your_webhook_secret_here

# IPFS/Filebase Configuration
FILEBASE_API_TOKEN=your_filebase_token_here

# Server Configuration
NODE_ENV=development
PORT=3000

# SSL Certificates (production only)
# SSL_KEY_PATH=/path/to/privkey.pem
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_CA_PATH=/path/to/chain.pem
